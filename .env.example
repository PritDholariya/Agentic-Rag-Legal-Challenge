# LLM & Generation Configuration
GEMINI_API_KEY=your_free_gemini_api_key
OPENAI_API_KEY=your_openai_api_key_optional
LLM_MODEL=gemini-2.5-flash

# Embeddings & Reranking Configuration
USE_COHERE_EMBEDDINGS=1
COHERE_API_KEY=your_cohere_api_key_optional
VOYAGE_API_KEY=your_voyage_api_key_optional

# Local Dataset & Output Paths (Self-Contained Evaluation Suite)
DOCS_DIR=docs_corpus
QUESTIONS_PATH=public_dataset/questions.json
OUTPUT_REPORT_PATH=evaluation_report.json
SUBMISSION_PATH=submission.json
CODE_ARCHIVE_PATH=code_archive.zip

# Optional Remote REST API Settings (Only needed if deploying against external challenge server)
# EVAL_API_KEY=your_optional_api_key
# EVAL_BASE_URL=https://platform.agentic-challenge.ai/api/v1
